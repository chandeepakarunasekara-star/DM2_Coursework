# Copy to .env and fill in to switch from demo mode to real databases.
# Leave everything commented out to run in demo mode (embedded SQLite +
# embedded JSON document store) - the app works with zero configuration.

PORT=3000
SESSION_SECRET=change-me-in-production

# --- Oracle (optional) ---
# Requires: npm install oracledb
# ORACLE_USER=courseconnect
# ORACLE_PASSWORD=your_password
# ORACLE_CONNECT_STRING=localhost/XEPDB1

# --- MongoDB (optional) ---
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=courseconnect
